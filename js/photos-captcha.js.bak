/* photos-human-verify:v1 */
var PHOTOS_VERIFY_TTL_MS = 0; // 0 = sempre exigir verificação ao abrir a galeria. Ex: 15*60*1000 para 15 min.

function _photosNow() { try { return Date.now ? Date.now() : (new Date()).getTime(); } catch (e) { return (new Date()).getTime(); } }

function clearPhotosHumanVerified() {
  try { sessionStorage.removeItem("photos_human_verified"); } catch (e) {}
  try { sessionStorage.removeItem("photos_human_verified_at"); } catch (e) {}
  try { delete sessionStorage.photos_human_verified; } catch (e) {}
  try { delete sessionStorage.photos_human_verified_at; } catch (e) {}
}

function setPhotosHumanVerified() {
  try {
    var now = String(_photosNow());
    try { sessionStorage.setItem("photos_human_verified", "1"); } catch (e) {}
    try { sessionStorage.setItem("photos_human_verified_at", now); } catch (e) {}
    try { sessionStorage.photos_human_verified = "1"; } catch (e) {}
    try { sessionStorage.photos_human_verified_at = now; } catch (e) {}
  } catch (e) {}
}

function isPhotosHumanVerified() {
  try {
    if (!PHOTOS_VERIFY_TTL_MS || PHOTOS_VERIFY_TTL_MS <= 0) return false;
    var flag = null;
    try { flag = sessionStorage.getItem("photos_human_verified"); } catch (e) { flag = null; }
    if (!flag) { try { flag = sessionStorage.photos_human_verified; } catch (e) { flag = null; } }
    if (flag !== "1") return false;

    var at = 0;
    try { at = Number(sessionStorage.getItem("photos_human_verified_at") || "0"); } catch (e) { at = 0; }
    if (!at) { try { at = Number(sessionStorage.photos_human_verified_at || "0"); } catch (e) { at = 0; } }
    if (!at) return false;

    return (_photosNow() - at) <= PHOTOS_VERIFY_TTL_MS;
  } catch (e) {
    return false;
  }
}

(function () {
  try {
    var at = 0;
    try { at = Number(sessionStorage.getItem("photos_human_verified_at") || "0"); } catch (e) { at = 0; }
    if (at && PHOTOS_VERIFY_TTL_MS > 0 && (_photosNow() - at) > PHOTOS_VERIFY_TTL_MS) {
      clearPhotosHumanVerified();
    }
    if (PHOTOS_VERIFY_TTL_MS <= 0) {
      clearPhotosHumanVerified();
    }
  } catch (e) {}
})();

(function photosCaptchaGate() {
  const BLUR_CLASS = "media-grid--blur";
  const VERIFY_URL = "https://withered-band-5ff3.dgulhak.workers.dev/verify";
  const PLACEHOLDER_MSG = "Captcha configurado com sucesso! ";
  const RESET_DELAY = 400;
  const SCRIPT_CHECK_DELAY = 1500;

  let overlay;
  let grid;
  let errorEl;
  let widgetEl;
  let initialized = false;
  let verifying = false;
  let resetScheduled = false;
  let placeholderActive = false;

  const isVerified = () => {
    return isPhotosHumanVerified();
  };

  const setVerified = () => {
    setPhotosHumanVerified();
  };

  const showError = (msg) => {
    if (errorEl) errorEl.textContent = msg || "";
  };

  const lock = () => {
    overlay?.classList.remove("hidden");
    grid?.classList.add(BLUR_CLASS);
  };

  const unlock = () => {
    overlay?.classList.add("hidden");
    grid?.classList.remove(BLUR_CLASS);
    showError("");
  };

  const scheduleReset = () => {
    if (resetScheduled || placeholderActive) return;
    resetScheduled = true;
    setTimeout(() => {
      resetScheduled = false;
      try {
        window.turnstile?.reset?.();
      } catch (_) {}
    }, RESET_DELAY);
  };

  const verifyWithServer = async (token) => {
    try {
      const response = await fetch(VERIFY_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ token })
      });
      const data = await response.json().catch(() => null);
      return !!(data && (data.ok === true || data.success === true));
    } catch (_) {
      return false;
    }
  };

  const onTurnstileSuccess = async (token) => {
    if (!initialized || verifying) return;
    if (placeholderActive) {
      showError(PLACEHOLDER_MSG);
      return;
    }
    verifying = true;
    showError("");

    try {
      const ok = await verifyWithServer(token);
      if (ok) {
        setVerified();
        unlock();
        return;
      }

      showError("Não foi possível verificar. Tente novamente.");
      try { if (window.tryResetTurnstile) window.tryResetTurnstile(); } catch(e) {}
      scheduleReset();
    } finally {
      verifying = false;
    }
  };

  const onTurnstileError = () => {
    if (!initialized) return;
    if (placeholderActive) {
      showError(PLACEHOLDER_MSG);
      return;
    }
    showError("Não foi possível verificar. Tente novamente.");
      try { if (window.tryResetTurnstile) window.tryResetTurnstile(); } catch(e) {}
    scheduleReset();
  };

  const onTurnstileExpired = () => {
    if (!initialized) return;
    if (placeholderActive) {
      showError(PLACEHOLDER_MSG);
      return;
    }
    showError("Não foi possível verificar. Tente novamente.");
      try { if (window.tryResetTurnstile) window.tryResetTurnstile(); } catch(e) {}
    scheduleReset();
  };

  const checkTurnstileLoaded = () => {
    setTimeout(() => {
      if (!initialized || placeholderActive || typeof window.turnstile !== "undefined") return;
      showError("Não foi possível carregar a verificação. Desative o bloqueador e recarregue.");
    }, SCRIPT_CHECK_DELAY);
  };

  const initPhotosCaptchaGate = () => {
    if (initialized) return;
    overlay = document.getElementById("humanOverlay");
    grid = document.getElementById("mediaGrid");
    errorEl = document.getElementById("humanError") || document.getElementById("photosCaptchaError");
    widgetEl = document.getElementById("turnstileWidget") || document.querySelector("#photosCaptcha .cf-turnstile");

    if (!overlay || !grid || !widgetEl) return;

    const siteKey = widgetEl.dataset.sitekey || "";
    const verifyPlaceholder = !VERIFY_URL || VERIFY_URL.startsWith("__") || VERIFY_URL.includes("TURNSTILE_VERIFY_URL");
    const siteKeyPlaceholder = !siteKey || siteKey.startsWith("__") || siteKey.includes("TURNSTILE_SITE_KEY") || siteKey.includes("PASTE_SITE_KEY_HERE");

    placeholderActive = verifyPlaceholder || siteKeyPlaceholder;
    initialized = true;

    if (placeholderActive) {
      lock();
      showError(PLACEHOLDER_MSG);
      return;
    }

    if (isVerified()) {
      unlock();
    } else {
      lock();
      checkTurnstileLoaded();
    }
  };

  window.initPhotosCaptchaGate = initPhotosCaptchaGate;
  window.onTurnstileSuccess = onTurnstileSuccess;
  window.onTurnstileError = onTurnstileError;
  window.onTurnstileExpired = onTurnstileExpired;
})();

;/* turnstile-watchdog:v1 */
(function(){
  function tryResetTurnstile(){
    try{
      if (window.turnstile && typeof window.turnstile.reset === "function") {
        try { window.turnstile.reset(); } catch (e) {}
        return true;
      }
    }catch(e){}
    return false;
  }

  function markVerifying(){
    try { window.__photos_turnstile_verifying_since = Date.now(); } catch(e){}
  }
  function clearVerifying(){
    try { window.__photos_turnstile_verifying_since = 0; } catch(e){}
  }

  function wrapCallback(name, mode){
    try{
      var orig = window[name];
      window[name] = function(){
        if (mode === "success") markVerifying();
        if (mode === "error" || mode === "expired") { clearVerifying(); tryResetTurnstile(); }

        var r;
        try { if (typeof orig === "function") r = orig.apply(this, arguments); } catch(e) {}

        // Se o sucesso disparou mas o verify falhar depois, a UI costuma setar a msg de erro.
        // O watchdog abaixo cobre travamentos. Aqui só garantimos que não fica "marcado" pra sempre.
        if (mode === "success") {
          setTimeout(function(){ clearVerifying(); }, 15000);
        }
        return r;
      }
    }catch(e){}
  }

  wrapCallback("onTurnstileSuccess","success");
  wrapCallback("onTurnstileError","error");
  wrapCallback("onTurnstileExpired","expired");

  // Watchdog: se ficar "verifying" por > 12s, reseta e libera tentar de novo
  setInterval(function(){
    try{
      var since = Number(window.__photos_turnstile_verifying_since || 0);
      if (since && (Date.now() - since) > 12000) {
        clearVerifying();
        tryResetTurnstile();
      }
    }catch(e){}
  }, 1000);

  // expõe helper pra ser usado no código (se quiser chamar manualmente)
  try { window.tryResetTurnstile = tryResetTurnstile; } catch(e){}
})();
